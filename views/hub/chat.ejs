<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= activeProject ? '/' + activeProject.slug : 'Chat' %> — McLellan Hub</title>
<link rel="stylesheet" href="/hub.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/atom-one-dark.min.css">
</head>
<body class="hub-page">

<nav class="sidebar">
  <div class="sidebar-header">
    <a href="/" class="logo">McLellan Hub</a>
    <span class="user-badge"><%= user %></span>
  </div>
  <div class="sidebar-section">
    <a href="/c" class="new-chat-btn">+ New chat</a>
    <button type="button" class="upload-to-project-btn" id="open-upload-modal">📎 Upload to project</button>
  </div>
  <div class="sidebar-section">
    <a href="/crm" class="sidebar-nav-link">People</a>
  </div>
  <div class="sidebar-section">
    <h3>Projects <button type="button" class="sidebar-new-btn" id="new-project-btn" title="New project">+</button></h3>
    <ul class="project-list">
      <% for (const p of projects) { %>
      <li class="<%= activeProject?.slug === p.slug ? 'active' : '' %>">
        <a href="/p/<%= p.slug %>">/<%= p.slug %></a>
      </li>
      <% } %>
    </ul>
  </div>
  <div class="sidebar-section">
    <h3>Recent</h3>
    <ul class="conv-list">
      <% for (const c of (recentConvs || [])) { %>
      <li class="<%= conv?.id === c.id ? 'active' : '' %>">
        <a href="/c/<%= c.id %>"><%= c.title || 'Untitled' %></a>
      </li>
      <% } %>
    </ul>
  </div>
  <div class="sidebar-footer">
    <form method="POST" action="/logout"><button type="submit" class="logout-btn">Sign out</button></form>
  </div>
</nav>
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<main class="main-area chat-area">

  <div class="chat-header">
    <button type="button" class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu">☰</button>
    <% if (activeProject) { %>
    <h2>/<%= activeProject.slug %> <span class="project-name"><%= activeProject.name %></span></h2>
    <% } else { %>
    <h2 id="conv-title"><%= conv?.title || 'New conversation' %></h2>
    <% } %>

    <!-- Move conversation to project -->
    <% if (convId && !activeProject && projects.length) { %>
    <div class="move-to-project" id="move-to-project">
      <button type="button" class="move-btn" id="move-btn">Move to project</button>
      <div class="move-picker" id="move-picker" hidden>
        <select id="move-project-select">
          <% for (const p of projects) { %>
          <option value="<%= p.slug %>">/<%= p.slug %></option>
          <% } %>
        </select>
        <button type="button" id="move-confirm-btn">Move</button>
        <button type="button" id="move-cancel-btn">Cancel</button>
      </div>
    </div>
    <% } %>

    <!-- Model selector -->
    <div class="model-picker">
      <select id="model-select">
        <% for (const group of (availableModels || [])) { %>
          <optgroup label="<%= group.label %>">
            <% for (const m of group.models) { %>
              <option value="<%= m.key %>" data-tier="<%= m.tier %>" data-search="<%= m.search %>"><%= m.label %><%= m.search === 'native' ? ' ◉' : m.search === 'web-plugin' ? ' ○' : '' %></option>
            <% } %>
          </optgroup>
        <% } %>
      </select>
      <a href="/settings" class="model-settings-link">⚙ Model settings</a>
      <span class="search-legend">◉ native search &nbsp; ○ web plugin</span>
    </div>
  </div>

  <% if (activeProject) { %>
  <div class="project-docs" id="project-docs" data-slug="<%= activeProject.slug %>">
    <div class="project-docs-head">
      <span class="material-symbols-outlined" style="font-size:18px;vertical-align:-3px">description</span>
      <strong>Documents</strong>
      <span class="docs-count" id="docs-count">(<%= (projectDocs || []).length %>)</span>
      <button type="button" class="docs-upload-btn" id="docs-upload-here">+ Upload</button>
      <input type="file" id="docs-upload-input" accept=".docx,.pdf,.txt,.md,.csv" hidden>
    </div>
    <ul class="docs-list" id="docs-list">
      <% if ((projectDocs || []).length === 0) { %>
        <li style="padding:8px 12px;color:var(--text-muted);font-size:13px;">No documents yet.</li>
      <% } else { %>
        <% for (const d of projectDocs) { %>
          <li class="doc-item" data-id="<%= d.id %>">
            <a class="doc-link" href="#" data-id="<%= d.id %>" data-filename="<%= d.filename %>">📄 <%= d.filename %></a>
            <span class="doc-size"><%= ((d.size_bytes || 0) / 1024).toFixed(1) %> KB</span>
            <button class="doc-delete" data-id="<%= d.id %>" title="Delete">×</button>
          </li>
        <% } %>
      <% } %>
    </ul>
  </div>
  <% } %>

  <div class="messages" id="messages">
    <% for (const m of messages) { %>
    <div class="message message-<%= m.role %>" data-id="<%= m.id %>" data-rating="<%= m.rating || 0 %>">
      <div class="message-content" data-raw="<%- encodeURIComponent(m.content) %>"></div>
      <% if (m.role === 'assistant') { %>
      <div class="message-meta">
        <span class="model-tag"><%= m.model %></span>
        <% if (m.search_used) { %><span class="search-tag">search</span><% } %>
        <% if (m.cost_usd) { %><span class="cost-tag">$<%= m.cost_usd.toFixed(4) %></span><% } %>
        <div class="export-btns">
          <button class="export-btn" data-format="docx" data-id="<%= m.id %>">Word</button>
          <button class="export-btn" data-format="pdf" data-id="<%= m.id %>">PDF</button>
          <button class="export-btn" data-format="gdoc" data-id="<%= m.id %>">Google Doc</button>
        </div>
      </div>
      <% } %>
    </div>
    <% } %>
  </div>

  <div class="input-area">
    <div class="analysis-prompt-panel" id="analysis-prompt-panel" style="display:none">
      <label style="font-size:11px;color:var(--text-dim);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">Analysis prompt</label>
      <textarea id="analysis-prompt-text" rows="2" placeholder="e.g. Summarise this document and flag anything notable."></textarea>
      <div style="display:flex;gap:8px;margin-top:4px;">
        <button type="button" id="prompt-save-btn">Save</button>
        <button type="button" id="prompt-reset-btn">Reset to default</button>
      </div>
    </div>
    <div class="data-sovereignty-flag" id="sovereignty-flag" style="display:none">
      🔒 Sensitive mode — web search disabled; model sees only your prompt + project context
    </div>
    <form id="chat-form">
      <textarea
        id="msg-input"
        placeholder="<%= activeProject ? '/' + activeProject.slug + ' ' : '' %>Message…  (/recall terms · /newproject Name · /slug.new · Shift+Enter for newline)"
        rows="3"
        autofocus
      ></textarea>
      <div class="input-controls">
        <label class="search-provider-toggle" title="Should the model fetch references?">
          References needed
          <select id="search-provider">
            <option value="openrouter" selected>Yes — OpenRouter</option>
            <option value="brave">Yes — Brave</option>
            <option value="off">No</option>
          </select>
        </label>
        <label class="search-depth-toggle" id="search-depth-wrap" title="How much source content to retrieve">
          Depth
          <select id="search-depth">
            <option value="low">Quick</option>
            <option value="medium" selected>Standard</option>
            <option value="high">Deep</option>
          </select>
        </label>
        <label class="sovereignty-toggle">
          <input type="checkbox" id="sovereignty-check"> Sensitive work
        </label>
        <label class="research-mode-toggle" title="Instructs the model to return a structured, cited research report">
          <input type="checkbox" id="research-mode-check"> Research report
        </label>
        <label class="attach-btn" title="Attach .docx, .pdf, .txt, .md, or .csv">
          <input type="file" id="attach-input" accept=".docx,.pdf,.txt,.md,.csv" hidden>
          <span>📎 Attach</span>
        </label>
        <label class="auto-analyse-toggle" title="Automatically analyse document when attached">
          <input type="checkbox" id="auto-analyse-check" checked> Auto-analyse
        </label>
        <button type="button" id="edit-prompt-btn" class="edit-prompt-btn" title="Edit analysis prompt">✏</button>
        <span id="upload-status" class="upload-status"></span>
        <button type="submit" id="send-btn">Send</button>
        <button type="button" id="stop-btn" class="stop-btn" hidden>Stop</button>
      </div>
    </form>
  </div>

</main>

<!-- New project modal -->
<div class="upload-modal-backdrop" id="np-backdrop"></div>
<div class="upload-modal" id="np-modal" role="dialog" aria-hidden="true">
  <h3>New project</h3>
  <p style="color:var(--text-dim);font-size:13px;">Give it a name — the slug is generated automatically. You can refine settings in Admin later.</p>
  <label style="display:block;margin-bottom:8px;font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">Project name</label>
  <input type="text" id="np-name" placeholder="e.g. Client Research" style="width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;font-family:var(--font);background:var(--bg);color:var(--text);">
  <div id="np-status" style="font-size:13px;color:var(--text-dim);margin-top:8px;min-height:18px;"></div>
  <div class="upload-modal-actions">
    <button type="button" id="np-cancel">Cancel</button>
    <button type="button" id="np-submit">Create</button>
  </div>
</div>

<!-- Upload-to-project modal -->
<div class="upload-modal-backdrop" id="upload-modal-backdrop"></div>
<div class="upload-modal" id="upload-modal" role="dialog" aria-hidden="true">
  <h3>Upload document to a project</h3>
  <p style="color:var(--text-dim);font-size:13px;">Converts to markdown and stores under the chosen project. Injected as context on every future /slug query.</p>
  <label style="display:block;margin-bottom:8px;font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">Project</label>
  <select id="upload-project-select">
    <% for (const p of projects) { %>
      <option value="<%= p.slug %>" <%= activeProject?.slug === p.slug ? 'selected' : '' %>>/<%= p.slug %> — <%= p.name %></option>
    <% } %>
  </select>
  <label style="display:block;margin-top:14px;margin-bottom:8px;font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">File (.docx, .pdf, .txt, .md, .csv)</label>
  <input type="file" id="upload-modal-file" accept=".docx,.pdf,.txt,.md,.csv">
  <div id="upload-modal-status" style="font-size:13px;color:var(--text-dim);margin-top:8px;min-height:18px;"></div>
  <div class="upload-modal-actions">
    <button type="button" id="upload-modal-cancel">Cancel</button>
    <button type="button" id="upload-modal-submit">Upload</button>
  </div>
</div>

<!-- Document viewer modal -->
<div class="doc-viewer-backdrop" id="doc-viewer-backdrop"></div>
<div class="doc-viewer" id="doc-viewer" role="dialog" aria-hidden="true">
  <div class="doc-viewer-head">
    <strong id="doc-viewer-title">Document</strong>
    <button type="button" id="doc-viewer-close">✕</button>
  </div>
  <pre id="doc-viewer-body"></pre>
</div>

<script>
  window.CONV_ID = '<%= convId || "" %>';
  window.PROJECT_SLUG = '<%= activeProject?.slug || "" %>';
</script>
<script src="https://cdn.jsdelivr.net/npm/marked@12.0.0/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/core.min.js"></script>
<script src="/hub-chat.js?v=20260424-project-docs"></script>
<script>

  // New project modal
  (function() {
    const openBtn = document.getElementById('new-project-btn');
    const modal = document.getElementById('np-modal');
    const backdrop = document.getElementById('np-backdrop');
    const cancelBtn = document.getElementById('np-cancel');
    const submitBtn = document.getElementById('np-submit');
    const nameInput = document.getElementById('np-name');
    const statusEl = document.getElementById('np-status');
    if (!openBtn) return;
    function open() { modal.classList.add('open'); backdrop.classList.add('active'); nameInput.value = ''; statusEl.textContent = ''; setTimeout(() => nameInput.focus(), 80); }
    function close() { modal.classList.remove('open'); backdrop.classList.remove('active'); submitBtn.disabled = false; submitBtn.textContent = 'Create'; }
    openBtn.addEventListener('click', open);
    cancelBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    nameInput.addEventListener('keydown', e => { if (e.key === 'Enter') submitBtn.click(); });
    submitBtn.addEventListener('click', async () => {
      const name = nameInput.value.trim();
      if (!name) { statusEl.textContent = 'Enter a project name.'; return; }
      submitBtn.disabled = true; submitBtn.textContent = 'Creating…';
      try {
        const r = await fetch('/api/projects', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name }) });
        const d = await r.json();
        if (!r.ok) { statusEl.textContent = '✖ ' + (d.error || 'Failed'); submitBtn.disabled = false; submitBtn.textContent = 'Create'; return; }
        window.location.href = '/p/' + d.project.slug;
      } catch (err) { statusEl.textContent = '✖ ' + err.message; submitBtn.disabled = false; submitBtn.textContent = 'Create'; }
    });
  })();

  // Move conversation to project
  const moveBtn = document.getElementById('move-btn');
  const movePicker = document.getElementById('move-picker');
  const moveCancelBtn = document.getElementById('move-cancel-btn');
  const moveConfirmBtn = document.getElementById('move-confirm-btn');
  if (moveBtn) {
    moveBtn.addEventListener('click', () => {
      moveBtn.hidden = true;
      movePicker.hidden = false;
    });
    moveCancelBtn.addEventListener('click', () => {
      movePicker.hidden = true;
      moveBtn.hidden = false;
    });
    moveConfirmBtn.addEventListener('click', async () => {
      const slug = document.getElementById('move-project-select').value;
      moveConfirmBtn.disabled = true;
      moveConfirmBtn.textContent = 'Moving…';
      const r = await fetch(`/api/conversations/${window.CONV_ID}/move`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ projectSlug: slug }),
      });
      if (r.ok) {
        window.location.href = `/p/${slug}`;
      } else {
        moveConfirmBtn.textContent = 'Error';
        moveConfirmBtn.disabled = false;
      }
    });
  }
</script>

</body>
</html>
